# ── Claude / Anthropic ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-20250514
ANTHROPIC_MODEL_TRIAGE=claude-haiku-4-5-20251001

# ── OpenAI (RAG embeddings only — ingest + retrieve_context) ─
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: Azure / proxy (leave empty for api.openai.com)
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/v1

# ── Datadog (optional — for coverage validation) ─────────────
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com

# ── GitHub App ───────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_SLUG=lumis
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_private_key
GITHUB_WEBHOOK_SECRET=

# ── GitLab ──────────────────────────────────────────────────
GITLAB_APP_ID=
GITLAB_APP_SECRET=
GITLAB_WEBHOOK_SECRET=

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sre:local_only@postgres:5432/lumis

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Object Storage (MinIO locally, S3 in staging) ────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=lumis
S3_REGION=us-east-1

# ── App ──────────────────────────────────────────────────────
ENV=local
DEBUG=true
LOG_LEVEL=debug
SECRET_KEY=local-dev-secret-change-in-production-min-32-chars!!
API_KEY_SALT=local-salt-change-in-production-min-32-chars!!!!

# ── Google Sign-In (OAuth 2.0) — optional ───────────────────
# Create OAuth client: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
