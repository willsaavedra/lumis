# ── API Gateway (nginx + Let's Encrypt) ──────────────────────
# Required when running the `gateway` service in docker-compose.
# DOMAIN must have a public A/AAAA record pointing to this host.
DOMAIN=api.horion.pro
CERTBOT_EMAIL=ops@horion.pro
# Set CERTBOT_STAGING=true while testing to avoid LE rate limits.
# Staging certs are NOT trusted by browsers — switch to false for real traffic.
CERTBOT_STAGING=false

# ── Claude / Anthropic ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-20250514
ANTHROPIC_MODEL_TRIAGE=claude-haiku-4-5-20251001

# ── CerebraAI (OpenAI-compatible / vLLM) ────────────────────
# Used when the user selects "CerebraAI" in the analysis modal.
CEREBRA_AI_BASE_URL=http://52.86.35.131:8001/v1
CEREBRA_AI_API_KEY=
CEREBRA_AI_MODEL_PRIMARY=Qwen/Qwen3.5-35B-A3B-FP8
CEREBRA_AI_MODEL_TRIAGE=Qwen/Qwen3.5-35B-A3B-FP8
CEREBRA_AI_TEMPERATURE=0.4
CEREBRA_AI_TOP_P=0.9
CEREBRA_AI_TIMEOUT=300

# ── OpenAI (RAG embeddings only — ingest + retrieve_context) ─
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: Azure / proxy (leave empty for api.openai.com)
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/v1

# ── Datadog (optional — for coverage validation) ─────────────
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com

# ── GitHub App ───────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_SLUG=lumis
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_private_key
GITHUB_WEBHOOK_SECRET=

# ── GitLab ──────────────────────────────────────────────────
GITLAB_APP_ID=
GITLAB_APP_SECRET=
GITLAB_WEBHOOK_SECRET=

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sre:local_only@postgres:5432/lumis

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Object Storage (MinIO locally, S3 in staging) ────────────
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=lumis
S3_REGION=us-east-1

# ── Agent (worker calls this URL to run the analysis graph) ──
# Docker Compose: http://agent:8001 · local API+worker only: http://localhost:8001
AGENT_BASE_URL=http://agent:8001

# ── App ──────────────────────────────────────────────────────
ENV=local
DEBUG=true
LOG_LEVEL=debug
SECRET_KEY=local-dev-secret-change-in-production-min-32-chars!!
API_KEY_SALT=local-salt-change-in-production-min-32-chars!!!!

# ── Public URLs (OAuth redirects, Stripe return URLs, invite links) ──
# FRONTEND_URL: after Google OAuth the API redirects the browser here (/callback?token=...).
# Local: http://localhost:3000 · Production (CloudFront): https://ai.horion.pro
FRONTEND_URL=http://localhost:3000
# API_BASE_URL: public base URL of this API. Default Google redirect_uri is {API_BASE_URL}/auth/google/callback.
# Local: http://localhost:8000 · Production (gateway TLS): https://api.horion.pro
API_BASE_URL=http://localhost:8000

# ── Google Sign-In (OAuth 2.0) — optional ───────────────────
# Create OAuth client: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add both if you use local + prod):
#   http://localhost:8000/auth/google/callback
#   https://api.horion.pro/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_METER_ID=mtr_...

# Stripe Price IDs (run `make stripe-fixture` to generate)
STRIPE_PRICE_STARTER_BASE=price_...
STRIPE_PRICE_STARTER_OVERAGE=price_...
STRIPE_PRICE_GROWTH_BASE=price_...
STRIPE_PRICE_GROWTH_OVERAGE=price_...
STRIPE_PRICE_SCALE_BASE=price_...
STRIPE_PRICE_SCALE_OVERAGE=price_...

# ── Slack (optional — for alerts) ────────────────────────────
SLACK_WEBHOOK_URL=
